<Window x:Class="NetworkGuardian.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NetworkGuardian"
        mc:Ignorable="d"
        Title="DashboardWindow" Height="450" Width="800">
	<Grid Margin="20">

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<TextBlock
			Text="🛡 Network Guardian"
			FontSize="28"
			FontWeight="Bold"
			Margin="0,0,0,20"/>

		<TextBlock
			Grid.Row="1"
			x:Name="TpStatus"
			Text="TP-Link : Unknown"
			FontSize="18"
			Margin="0,10"/>

		<TextBlock
			Grid.Row="2"
			x:Name="TendaStatus"
			Text="Tenda : Unknown"
			FontSize="18"
			Margin="0,10"/>

		<TextBlock
			Grid.Row="3"
			x:Name="WifiDirectStatus"
			Text="Wi-Fi Direct : Unknown"
			FontSize="18"
			Margin="0,10"/>

		<TextBlock
			Grid.Row="4"
			x:Name="InternetStatus"
			Text="Internet : Unknown"
			FontSize="18"
			Margin="0,10"/>

		<TextBlock
			Grid.Row="5"
			x:Name="HotspotStatus"
			Text="Hotspot : Unknown"
			FontSize="18"
			Margin="0,10"/>

	</Grid>
</Window>
